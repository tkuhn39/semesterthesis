# Example environment configuration. Copy to `.env` and adjust.
# `.env` is git-ignored and must never be committed.

# --- General -------------------------------------------------------------------
APP_ENV=development          # development | production
TIMEZONE=Europe/Berlin       # CET/CEST per project rules
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# --- Backend (FastAPI) ---------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# Comma-separated origins allowed by CORS (frontend dev server, etc.)
CORS_ORIGINS=http://localhost:5173

# --- Frontend ------------------------------------------------------------------
# Base URL the SPA uses to reach the API (Vite reads VITE_-prefixed vars).
VITE_API_BASE_URL=http://localhost:8000

# --- Paths ---------------------------------------------------------------------
OUTPUT_DIR=80_output
LOG_DIR=90_logs
