# =============================================================================
# Single source of truth for ALL configuration (project_rules.md §15-17).
# Copy to `.env` and adjust. `.env` is git-ignored and must never be committed.
# Backend reads these via app.config.Settings; the frontend reads VITE_* values
# from this same file (Vite envDir).
# =============================================================================

# --- General -----------------------------------------------------------------
APP_ENV=development            # development | production
NODE_NAME=local               # identifies this process/node in logs (HA)
TIMEZONE=Europe/Berlin        # CET/CEST per project rules
LOG_LEVEL=INFO                # DEBUG | INFO | WARNING | ERROR
LOG_TO_STDOUT=true            # true in containers/multi-node; aggregate logs externally

# --- Paths (never hardcode paths in code; set them here) ---------------------
# Persisted results go through app.storage (STORAGE_LOCAL_BASE_PATH below).
CACHE_DIR=60_cache            # disposable cache (mesh/FE intermediates); safe to delete
LOG_DIR=90_logs               # only used when LOG_TO_STDOUT=false

# --- Backend (FastAPI) -------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173   # comma-separated list of allowed origins

# --- Frontend (read by Vite) -------------------------------------------------
# Base URL the SPA uses to reach the API. Empty = same-origin (single Docker
# image). Set to a full URL when frontend and backend are deployed separately.
VITE_API_BASE_URL=http://localhost:8000

# =============================================================================
# Object / file storage  (STORAGE_BACKEND = local | s3)
# Switch backends here only — application code never changes.
# =============================================================================
STORAGE_BACKEND=local

# -- local: a directory (single-node / development only) ----------------------
STORAGE_LOCAL_BASE_PATH=80_output

# -- s3: ANY S3-compatible service (AWS S3, Cloudflare R2, Ceph, MinIO) -------
# Set STORAGE_BACKEND=s3 and fill these in:
S3_ENDPOINT_URL=              # e.g. https://<account>.r2.cloudflarestorage.com (omit for AWS S3)
S3_REGION=auto                # AWS region, or "auto" for R2
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_USE_PATH_STYLE=true        # true for R2/Ceph/MinIO, false for AWS virtual-hosted

# =============================================================================
# Database  (DATABASE_BACKEND = none | sqlite | postgres | d1)
# Extension point — see app/database/README.md.
# =============================================================================
DATABASE_BACKEND=none

# -- sqlite / postgres: a single DSN (may contain credentials) ----------------
# sqlite:   sqlite:///./data/app.db
# postgres: postgresql://user:pass@host:5432/dbname
DATABASE_URL=

# -- d1: Cloudflare D1 over HTTP ----------------------------------------------
D1_ACCOUNT_ID=
D1_DATABASE_ID=
D1_API_TOKEN=
